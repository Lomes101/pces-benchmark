# PCES Benchmark — required API keys
# Copy this file to .env and fill in your keys

# Groq API (required for multi_llm_eval.py)
# Get yours at: https://console.groq.com
GROQ_KEY_1=your_groq_key_here
GROQ_KEY_2=your_groq_key_here  # optional — for key rotation

# OpenRouter API (optional — for additional models)
# Get yours at: https://openrouter.ai
OPENROUTER_KEY=your_openrouter_key_here
